# Copy to .env and fill in. The desktop app will write its own .env-equivalent
# via the settings UI in Phase 3; this file is for the headless dev loop.

BASETEN_API_KEY=

INFERENCE_PROVIDER=baseten-anthropic
INFERENCE_BASE_URL=https://inference.baseten.co
INFERENCE_MODEL=zai-org/GLM-5.2

LITELLM_PROXY_URL=http://127.0.0.1:4000
MAX_OUTPUT_TOKENS=8192
