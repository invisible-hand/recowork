{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capability set for the main window.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:path:default",
    "shell:default",
    "shell:allow-stdin-write",
    "shell:allow-kill",
    "shell:allow-open",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        { "name": "node", "cmd": "node", "args": true },
        { "name": "container", "cmd": "container", "args": true }
      ]
    },
    {
      "identifier": "shell:allow-spawn",
      "allow": [
        { "name": "node", "cmd": "node", "args": true },
        { "name": "container", "cmd": "container", "args": true }
      ]
    },
    "store:default",
    "dialog:default"
  ]
}
